{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/skills/*.md"
  ],
  "mcp": {
    "agent-memory": {
      "type": "local",
      "command": ["npx", "-y", "@agentmemory/mcp-server"],
      "enabled": true
    },
    "stitch": {
      "type": "local",
      "command": ["npx", "-y", "@stitch/mcp-server"],
      "enabled": true
    }
  }
}
