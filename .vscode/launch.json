{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug Frontend (Chrome)",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/*",
        "meteor://💻app/*": "${webRoot}/*"
      }
    },
    {
      "type": "edge",
      "request": "launch",
      "name": "Debug Frontend (Edge)",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/src"
    },
    {
      "name": "Debug Backend (NestJS)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "start:debug"
      ],
      "console": "integratedTerminal",
      "outFiles": [
        "${workspaceFolder}/backend/dist/**/*.js"
      ],
      "restart": true
    }
  ],
  "compounds": [
    {
      "name": "Debug Fullstack (Chrome)",
      "configurations": ["Debug Backend (NestJS)", "Debug Frontend (Chrome)"]
    }
  ]
}
